secrets.properties

# Clave privada RSA usada para firmar peticiones a la API
app/src/main/assets/private_key.pem

# Keystore de firma del APK
*.jks
*.keystore
keystore.properties

# Variables de entorno locales
.env
.env.local
.env.*.local

# ─── SDK local ────────────────────────────────────────────────────────────────
# Contiene rutas absolutas de la máquina del desarrollador
local.properties

# ─── Logs y temporales ────────────────────────────────────────────────────────
*.log
*.tmp
*.swp
*.swo
*~
