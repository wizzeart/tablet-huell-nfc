# ─── Git LFS — archivos binarios grandes ──────────────────────────────────────
# Requiere Git LFS instalado: https://git-lfs.github.com/
# Después de clonar: git lfs pull
# ──────────────────────────────────────────────────────────────────────────────

# Modelo TTS neuronal (~36 MB)
*.onnx filter=lfs diff=lfs merge=lfs -text

# Librerías nativas Android (~60 MB)
*.so   filter=lfs diff=lfs merge=lfs -text

# JARs (librerías Java parcheadas — no están en Maven Central)
*.jar  filter=lfs diff=lfs merge=lfs -text

# Keystores de firma (por si se añaden en el futuro)
*.jks      filter=lfs diff=lfs merge=lfs -text
*.keystore filter=lfs diff=lfs merge=lfs -text

# ─── Normalización de fin de línea ────────────────────────────────────────────
# Archivos de texto: LF en el repo, conversión automática en Windows
*.java      text eol=lf
*.gradle    text eol=lf
*.xml       text eol=lf
*.properties text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf

# Gradle wrapper — mantener ejecutable en Unix
gradlew     text eol=lf
