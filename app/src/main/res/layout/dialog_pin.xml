<?xml version="1.0" encoding="utf-8"?>
<!-- Equivalente del modal PIN en scanning.html:104-136 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="400dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/color_surface"
    android:padding="28dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pin_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/color_text_primary"
        android:layout_marginBottom="18dp" />

    <TextView
        android:id="@+id/tv_pin_display"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="32sp"
        android:textColor="@color/color_primary"
        android:letterSpacing="0.5"
        android:layout_marginBottom="14dp"
        android:minHeight="40dp" />

    <TextView
        android:id="@+id/tv_pin_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="@color/color_error"
        android:visibility="gone"
        android:layout_marginBottom="14dp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4"
        android:alignmentMode="alignBounds"
        android:useDefaultMargins="false">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_1"
            style="@style/KioskButton.Outline"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="5dp"
            android:text="1"
            android:textSize="22sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_2"
            style="@style/KioskButton.Outline"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="5dp"
            android:text="2"
            android:textSize="22sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_3"
            style="@style/KioskButton.Outline"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="5dp"
            android:text="3"
            android:textSize="22sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_4"
            style="@style/KioskButton.Outline"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="5dp"
            android:text="4"
            android:textSize="22sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_5"
            style="@style/KioskButton.Outline"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="5dp"
            android:text="5"
            android:textSize="22sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_6"
            style="@style/KioskButton.Outline"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="5dp"
            android:text="6"
            android:textSize="22sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_7"
            style="@style/KioskButton.Outline"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="5dp"
            android:text="7"
            android:textSize="22sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_8"
            style="@style/KioskButton.Outline"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="5dp"
            android:text="8"
            android:textSize="22sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_9"
            style="@style/KioskButton.Outline"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="5dp"
            android:text="9"
            android:textSize="22sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pin_delete"
            style="@style/KioskButton.Outline"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="5dp"
            android:text="⌫"
            android:textSize="22sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_0"
            style="@style/KioskButton.Outline"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="5dp"
            android:text="0"
            android:textSize="22sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pin_ok"
            style="@style/KioskButton"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="5dp"
            android:text="OK"
            android:textSize="20sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </GridLayout>

</LinearLayout>
