<?xml version="1.0" encoding="utf-8"?>
<!-- Equivalente del modal #tankSelectorModal en main_screen.html -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <!-- Header: fondo oscuro con borde inferior amarillo — equivalente border-bottom: 2px solid #ffaa00 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:background="@color/color_surface">

        <TextView
            android:id="@+id/tv_tank_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tank_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/color_tank"
            android:letterSpacing="0.08" />

        <Button
            android:id="@+id/btn_tank_close"
            style="@style/KioskButton.Danger"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="✕"
            android:textSize="18sp"
            android:padding="0dp" />
    </LinearLayout>

    <!-- Separador con color amarillo (border-bottom del header) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/color_tank" />

    <!-- Área de estado (loading / error) -->
    <TextView
        android:id="@+id/tv_tank_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tank_loading"
        android:textSize="18sp"
        android:textColor="@color/color_text_secondary"
        android:gravity="center"
        android:padding="48dp"
        android:visibility="visible" />

    <!-- Contenido scrollable: grupos de tanques + botón guardar -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/ll_tank_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp" />
    </ScrollView>

    <!-- Botón guardar (siempre visible en la parte inferior) -->
    <Button
        android:id="@+id/btn_tank_save"
        style="@style/KioskButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/tank_save"
        android:textSize="16sp"
        android:layout_margin="16dp"
        android:visibility="gone" />

</LinearLayout>
