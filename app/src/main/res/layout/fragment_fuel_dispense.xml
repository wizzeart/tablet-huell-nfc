<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/fuel_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_fuel_back"
            style="@style/KioskButton.Outline"
            android:layout_width="140dp"
            android:layout_height="48dp"
            android:text="@string/btn_back" />

        <TextView
            android:id="@+id/tv_fuel_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/fuel_title"
            android:textColor="@color/color_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="140dp"
            android:layout_height="1dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/fuel_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:baselineAligned="false"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/fuel_header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingEnd="16dp">

                <TextView
                    android:id="@+id/tv_fuel_worker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/color_surface_elevated"
                    android:padding="18dp"
                    android:textColor="@color/color_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/fuel_bidon_label"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_fuel_bidon_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="-"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/fuel_vehicle_label"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/ll_fuel_vehicles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/tv_fuel_no_vehicles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/fuel_no_vehicles"
                    android:textColor="@color/color_error"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/fuel_select_assignment"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/ll_fuel_assignments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/tv_fuel_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@color/color_surface"
                    android:padding="16dp"
                    android:text="@string/fuel_loading"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:layout_width="360dp"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/color_surface_elevated"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_fuel_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/fuel_type"
                    android:textColor="@color/color_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_fuel_qty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="0.00 L"
                    android:textColor="@color/color_text_primary"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:hint="@string/fuel_amount_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_fuel_liters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:inputType="numberDecimal"
                        android:textColor="@color/color_text_primary"
                        android:textSize="30sp"
                        android:textStyle="bold" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btn_fuel_dispense"
                    style="@style/KioskButton"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="22dp"
                    android:text="@string/fuel_dispense" />

                <TextView
                    android:id="@+id/tv_fuel_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="120dp"
                    android:layout_marginTop="18dp"
                    android:visibility="gone"
                    android:background="@color/color_background"
                    android:padding="12dp"
                    android:textColor="@color/color_success"
                    android:textSize="13sp"
                    android:typeface="monospace" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Comprobante compacto -->
    <LinearLayout
        android:id="@+id/ll_fuel_confirm_panel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/fuel_header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/ll_fuel_invoice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_fuel_invoice"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_fuel_invoice_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/fuel_invoice_title"
                android:textColor="@color/color_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.06" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"
                android:text="@string/fuel_invoice_review"
                android:textColor="@color/color_text_secondary"
                android:textSize="12sp"
                android:gravity="center" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_fuel_invoice_item">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/fuel_invoice_user_ci"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_invoice_worker"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/color_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:maxLines="2"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/tv_invoice_ci"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp"
                            android:maxLines="1"
                            android:ellipsize="end" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_fuel_invoice_item">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/fuel_invoice_fuel"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_invoice_fuel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/color_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:maxLines="2"
                            android:ellipsize="end" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_fuel_invoice_item">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/fuel_invoice_vehicle"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_invoice_vehicle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/color_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:maxLines="2"
                            android:ellipsize="end" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_fuel_invoice_item">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/fuel_invoice_bidon"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_invoice_bidon"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:maxLines="2"
                            android:ellipsize="end" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_fuel_invoice_item">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/fuel_invoice_withdraw"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_invoice_withdraw"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/color_neon_yellow"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_fuel_confirm_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btn_fuel_confirm_proceed"
                style="@style/KioskButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="@string/fuel_invoice_proceed" />

            <Button
                android:id="@+id/btn_fuel_confirm_cancel"
                style="@style/KioskButton.Outline"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/fuel_confirm_cancel" />
        </LinearLayout>
    </LinearLayout>

    <!-- Modal flotante de confirmación por huella -->
    <FrameLayout
        android:id="@+id/overlay_fuel_fingerprint"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="@color/color_overlay"
        android:clickable="true"
        android:focusable="true"
        android:elevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/fuel_header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/ll_fuel_fingerprint_modal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="24dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_fuel_invoice"
            android:padding="24dp">

            <ImageView
                android:id="@+id/iv_fuel_confirm_icon"
                android:layout_width="64dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_fingerprint"
                app:tint="@color/color_primary"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_fuel_confirm_instruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/fuel_confirm_waiting"
                android:textColor="@color/color_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_fuel_confirm_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <ImageView
                android:id="@+id/iv_fuel_confirm_preview"
                android:layout_width="120dp"
                android:layout_height="150dp"
                android:visibility="gone"
                android:scaleType="fitCenter"
                android:contentDescription="@string/fuel_confirm_waiting"
                android:background="@drawable/bg_neon_preview"
                android:padding="8dp"
                android:elevation="12dp"
                android:outlineSpotShadowColor="@color/color_primary"
                android:outlineAmbientShadowColor="@color/color_primary" />
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
