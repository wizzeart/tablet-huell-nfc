# ─── secrets.properties.example ───────────────────────────────────────────────
# Copia este archivo como "secrets.properties" en la raíz del proyecto y
# rellena los valores reales. El archivo secrets.properties está en .gitignore
# y NUNCA debe subirse al repositorio.
#
# También coloca la clave RSA privada en:
#   app/src/main/assets/private_key.pem
# (ese path también está en .gitignore)
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL
DB_HOST=0.0.0.0
DB_PORT=5432
DB_NAME=nombre_de_la_base
DB_USER=usuario_db
DB_PASSWORD=contrasena_db

# API Petronova
PETRONOVA_BASE_URL=https://tudominio.com/api/
AGENT_ID=id_del_terminal

# Panel administrador
ADMIN_PASSWORD=cambia_esta_contrasena
EXIT_PIN=00000
